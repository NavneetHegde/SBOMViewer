@page "/"
@implements IDisposable
@inject SbomState SbomState
@inject ChatState ChatState

<FluentStack Orientation="Orientation.Vertical" Style="gap:1.5rem;">

    @if (SbomState.Document is not null && SbomState.Schema is not null)
    {
        <DynamicSbomViewer RootElement="@SbomState.Document.RootElement"
                           Schema="@SbomState.Schema"
                           FileName="@SbomState.FileName" />
    }
    else
    {
        <FluentCard Style="padding:1rem; text-align:center; color:var(--neutral-foreground-2);">
            No SBOM loaded yet. Please select a format and upload a file.

            @if (_betaBannerVisible)
            {
                <div class="beta-banner" style="margin-top:1rem; border-radius:0.375rem;">
                    <span>
                        <span class="beta-badge">&#x26A1; BETA</span>
                        Try WebLLM beta features integration at
                        <a href="https://staging.sbomviewer.com" target="_blank" rel="noopener noreferrer">staging.sbomviewer.com</a>
                    </span>
                    <button class="beta-banner-dismiss" @onclick="() => _betaBannerVisible = false" title="Dismiss" aria-label="Dismiss beta banner">&#x2715;</button>
                </div>
            }
        </FluentCard>
    }

</FluentStack>

@code {
    private bool _betaBannerVisible = true;

    protected override void OnInitialized()
    {
        SbomState.OnChange += StateHasChanged;
        ChatState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        SbomState.OnChange -= StateHasChanged;
        ChatState.OnChange -= StateHasChanged;
    }
}
